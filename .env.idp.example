# Local Logto IdP configuration template
# Copy this file to .env.idp and update with actual values after seeding.
#
# These variables are consumed by the backend API for OIDC token validation.
# Run `./scripts/seed-logto-dev.sh` after booting the IdP stack to generate .env.idp

# Issuer URL (points to your Logto OIDC endpoint)
OIDC_ISS=http://localhost:3301

# Resource indicator / Audience (your API's resource indicator in Logto)
OIDC_AUDIENCE=https://api.breakdown.local

# JWKS URL (where to fetch signing keys for JWT validation)
OIDC_JWKS_URL=http://localhost:3301/.well-known/jwks
